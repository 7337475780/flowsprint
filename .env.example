# ==========================================
# FLOWSPRINT MASTER ENVIRONMENT CONFIGURATION
# ==========================================

# ----------------------------
# BACKEND SERVER CONFIGURATION
# ----------------------------
# Host port and runtime environment mode
PORT=5000
NODE_ENV=development

# Mongoose connection string (MongoDB Instance)
MONGO_URI=mongodb://localhost:27017/flowsprint

# Cross-Origin Resource Sharing (CORS) allowed hosts
# Use a comma-separated list for multiple hosts or "*" for wildcard (not recommended in prod)
CORS_ORIGIN=http://localhost:5173

# API Request Rate Limiter (Max requests per window timeframe)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# JSON Web Token authentication secrets
JWT_SECRET=super_secret_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d


# ----------------------------
# FRONTEND CLIENT CONFIGURATION
# ----------------------------
# Local development server port (defined in vite.config)
VITE_PORT=5173

{
  "name": "flowsprint-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Express backend for FlowSprint, built with TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently -n \"tsc,nodemon\" -c \"blue,green\" \"tsc -w\" \"nodemon --delay 1 dist/server.js\"",
    "build:watch": "tsc -w",
    "start:watch": "nodemon dist/server.js",
    "build": "rimraf dist && tsc",
    "start": "node dist/server.js",
    "lint": "echo \"No lint script defined in server package yet\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.3",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.7",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
